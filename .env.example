# Copy to .env for LOCAL dev only. In prod, Doppler injects these.
# NEVER commit a real .env. See doppler.md for the canonical list.
#
# IMPORTANT: do NOT put inline comments after a value (e.g. `KEY=val  # note`).
# The .env reader treats everything after `=` as the value. Keep notes on their
# own line, like these.

# --- Runtime ---
FMML_ENV=local
LOG_LEVEL=INFO

# --- Anthropic (clue & persona generation) ---
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI (avatar image generation) ---
OPENAI_API_KEY=sk-proj-xxx
# gpt-image-1 (stable) or gpt-image-1.5 (newer); confirm the id in OpenAI docs
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024

# --- Supabase ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxx

# --- X API (single developer app) ---
X_API_KEY=xxx
X_API_SECRET=xxx
X_BEARER_TOKEN=xxx
# Main account @FindingMemeland OAuth 1.0a tokens
X_MAIN_ACCESS_TOKEN=xxx
X_MAIN_ACCESS_SECRET=xxx
# OAuth 2.0 (persona authorization flow, step 16)
X_CLIENT_ID=xxx
X_CLIENT_SECRET=xxx
# Persona tokens are stored per-account as X_PERSONA_<id>_* (added at step 16)

# --- Base chain ---
BASE_RPC_URL=https://mainnet.base.org
# Filled after Clanker deploy (checklist step 20)
FMML_TOKEN_ADDRESS=
# EOA, holds <= 2 hunts of prizes
HOT_WALLET_PRIVATE_KEY=
# Hardcoded per-hunt ceiling (token base units). Use 0 until set.
PAYOUT_CAP_FMML=0

# --- Telegram (approval queue + admin commands) ---
TELEGRAM_BOT_TOKEN=xxx
# Hardcoded; only this chat can trigger hunts
TELEGRAM_ADMIN_CHAT_ID=

# --- Game parameters ---
PRIZE_USD_MIN=200
PRIZE_USD_MAX=500
# Random secret; revealed per hunt in the Winner Announcement
INTEGRITY_SALT=
